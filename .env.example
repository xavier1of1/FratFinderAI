# Shared
APP_ENV=development

# Postgres / Supabase local stack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fratfinder
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/fratfinder

# Dashboard
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
WEB_DEFAULT_ACTOR=local-operator

# Crawler
CRAWLER_LOG_LEVEL=INFO
CRAWLER_HTTP_TIMEOUT_SECONDS=20
CRAWLER_HTTP_VERIFY_SSL=true
CRAWLER_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
CRAWLER_MAX_RETRIES=3
CRAWLER_RETRY_BACKOFF_SECONDS=1.0
CRAWLER_FIELD_JOB_WORKER_ID=local-crawler-worker
CRAWLER_FIELD_JOB_BASE_BACKOFF_SECONDS=30
CRAWLER_FIELD_JOB_MAX_WORKERS=8
CRAWLER_SEARCH_ENABLED=true
CRAWLER_SEARCH_PROVIDER=auto
CRAWLER_SEARCH_PROVIDER_ORDER_FREE=searxng_json,duckduckgo_html,bing_html
CRAWLER_SEARCH_MAX_RESULTS=5
CRAWLER_SEARCH_MAX_PAGES_PER_JOB=3
CRAWLER_SEARCH_CACHE_EMPTY_RESULTS=false
CRAWLER_SEARCH_CIRCUIT_BREAKER_FAILURES=3
CRAWLER_SEARCH_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
CRAWLER_SEARCH_MIN_REQUEST_INTERVAL_MS=0
CRAWLER_SEARCH_PROVIDER_PACING_MS_SEARXNG_JSON=0
CRAWLER_SEARCH_PROVIDER_PACING_MS_TAVILY_API=0
CRAWLER_SEARCH_PROVIDER_PACING_MS_SERPER_API=0
CRAWLER_SEARCH_PROVIDER_PACING_MS_DUCKDUCKGO_HTML=0
CRAWLER_SEARCH_PROVIDER_PACING_MS_BING_HTML=0
CRAWLER_SEARCH_PROVIDER_PACING_MS_BRAVE_HTML=0
CRAWLER_SEARCH_PREFLIGHT_ENABLED=false
CRAWLER_SEARCH_PREFLIGHT_PROBE_COUNT=3
CRAWLER_SEARCH_PREFLIGHT_MIN_SUCCESS_RATE=0.34
CRAWLER_SEARCH_DEGRADED_WORKER_CAP=2
CRAWLER_SEARCH_DEGRADED_MAX_RESULTS=3
CRAWLER_SEARCH_DEGRADED_MAX_PAGES_PER_JOB=1
CRAWLER_SEARCH_DEGRADED_EMAIL_MAX_QUERIES=3
CRAWLER_SEARCH_DEGRADED_INSTAGRAM_MAX_QUERIES=4
CRAWLER_SEARCH_DEGRADED_DEPENDENCY_WAIT_SECONDS=600
CRAWLER_SEARCH_NEGATIVE_COOLDOWN_DAYS=30
CRAWLER_SEARCH_DEPENDENCY_WAIT_SECONDS=300
CRAWLER_SEARCH_TRANSIENT_SHORT_RETRIES=2
CRAWLER_SEARCH_TRANSIENT_LONG_COOLDOWN_SECONDS=900
CRAWLER_SEARCH_MIN_NO_CANDIDATE_BACKOFF_SECONDS=60
CRAWLER_SEARCH_REQUIRE_CONFIDENT_WEBSITE_FOR_EMAIL=true
CRAWLER_SEARCH_EMAIL_ESCAPE_ON_PROVIDER_BLOCK=true
CRAWLER_SEARCH_EMAIL_ESCAPE_MIN_WEBSITE_FAILURES=2
CRAWLER_SEARCH_EMAIL_MAX_QUERIES=5
CRAWLER_SEARCH_INSTAGRAM_MAX_QUERIES=6
CRAWLER_SEARCH_ENABLE_SCHOOL_INITIALS=true
CRAWLER_SEARCH_MIN_SCHOOL_INITIAL_LENGTH=3
CRAWLER_SEARCH_ENABLE_COMPACT_FRATERNITY=true
CRAWLER_SEARCH_INSTAGRAM_ENABLE_HANDLE_QUERIES=true
CRAWLER_SEARCH_INSTAGRAM_DIRECT_PROBE_ENABLED=false
CRAWLER_DISCOVERY_VERIFIED_MIN_CONFIDENCE=0.65
CRAWLER_NAV_MAX_HOPS_PER_STUB=2
CRAWLER_NAV_MAX_PAGES_PER_RUN=60
GREEDY_COLLECT=none
CRAWLER_SEARCH_SEARXNG_BASE_URL=http://localhost:8888
CRAWLER_SEARCH_SEARXNG_ENGINES=
CRAWLER_SEARCH_TAVILY_API_KEY=
CRAWLER_SEARCH_SERPER_API_KEY=
CRAWLER_SEARCH_BRAVE_API_KEY=
CRAWLER_LLM_ENABLED=false
CRAWLER_LLM_MODEL=gpt-4o-mini
CRAWLER_LLM_MAX_TOKENS=2000
CRAWLER_LLM_MAX_CALLS_PER_RUN=3
OPENAI_API_KEY=your-openai-key-here
# Deprecated for new live executions; use explicit CLI/API runtime selection instead.
CRAWLER_RUNTIME_MODE=adaptive_assisted
CRAWLER_V3_EXECUTION_MODE=worker_service
CRAWLER_V3_REQUEST_WORKER_ID=local-request-worker
CRAWLER_V3_REQUEST_POLL_SECONDS=5
CRAWLER_V3_REQUEST_BATCH_LIMIT=10
CRAWLER_V3_REQUEST_STALE_MINUTES=45
CRAWLER_V3_FREE_RECOVERY_ATTEMPTS=3
CRAWLER_V3_CRAWL_RUNTIME_MODE=adaptive_assisted
CRAWLER_V3_FIELD_JOB_RUNTIME_MODE=langgraph_primary
CRAWLER_V3_FIELD_JOB_GRAPH_DURABILITY=sync
CRAWLER_V3_PAID_SEARCH_ENABLED=false
CRAWLER_V3_LLM_ENABLED=false
CRAWLER_V3_PROVISIONAL_PROMOTION_MODE=single_strong_official
CRAWLER_V3_REWARD_WEIGHTS={"precision":0.45,"coverage":0.35,"efficiency":0.2}
CRAWLER_FRONTIER_MAX_PAGES_PER_SOURCE=40
CRAWLER_FRONTIER_MAX_DEPTH=3
CRAWLER_FRONTIER_MAX_PAGES_PER_TEMPLATE=8
CRAWLER_FRONTIER_MAX_EMPTY_STREAK=5
CRAWLER_FRONTIER_HIGH_YIELD_RECORD_THRESHOLD=60
CRAWLER_FRONTIER_MIN_PAGES_FOR_HIGH_YIELD_STOP=2
CRAWLER_ADAPTIVE_EPSILON=0.1
CRAWLER_ADAPTIVE_MIN_SCORE=0.1
CRAWLER_ADAPTIVE_STOP_SATURATION_THRESHOLD=4
CRAWLER_POLICY_VERSION=adaptive-v1
CRAWLER_REPLAY_EXPORT_LIMIT=500

# Agentic / Adaptive RL
CRAWLER_ADAPTIVE_POLICY_RESTORE_ENABLED=true
CRAWLER_ADAPTIVE_TRAIN_DEFAULT_EPOCHS=3
CRAWLER_ADAPTIVE_TRAIN_DEFAULT_RUNTIME_MODE=adaptive_assisted
CRAWLER_ADAPTIVE_TRAIN_SOURCE_SLUGS=
CRAWLER_ADAPTIVE_EVAL_SOURCE_SLUGS=
CRAWLER_ADAPTIVE_EVAL_ENRICHMENT_LIMIT_PER_SOURCE=120
CRAWLER_ADAPTIVE_EVAL_ENRICHMENT_WORKERS=4
CRAWLER_ADAPTIVE_EVAL_ENRICHMENT_RUN_PREFLIGHT=true
CRAWLER_ADAPTIVE_EVAL_ENRICHMENT_REQUIRE_HEALTHY_SEARCH=true
BENCHMARK_CRAWL_RUNTIME_MODE=adaptive_assisted
BENCHMARK_FIELD_JOB_RUNTIME_MODE=langgraph_primary
BENCHMARK_RUN_ADAPTIVE_WARMUP=true
# Optional hard override (ms) for each benchmark field-job cycle timeout.
# Leave empty to use workload-aware timeout estimation.
BENCHMARK_CYCLE_TIMEOUT_MS=

# Agentic RL tuning knobs (V2.1)
CRAWLER_ADAPTIVE_LIVE_EPSILON=0.02
CRAWLER_ADAPTIVE_TRAIN_EPSILON=0.12
CRAWLER_ADAPTIVE_REWARD_GAMMA=0.85
CRAWLER_ADAPTIVE_TRACE_HOPS=4
CRAWLER_ADAPTIVE_REPLAY_WINDOW_DAYS=7
CRAWLER_ADAPTIVE_REPLAY_BATCH_SIZE=500
CRAWLER_ADAPTIVE_RISK_TIMEOUT_WEIGHT=0.75
CRAWLER_ADAPTIVE_RISK_REQUEUE_WEIGHT=0.35
CRAWLER_ADAPTIVE_BALANCED_KPI_WEIGHTS={"coverage":0.45,"throughput":0.2,"queue":0.2,"reliability":0.15}


# Field-job LangGraph runtime controls
CRAWLER_FIELD_JOB_RUNTIME_MODE=langgraph_primary
CRAWLER_FIELD_JOB_GRAPH_DURABILITY=sync


